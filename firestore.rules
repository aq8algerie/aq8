rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function isSuperAdmin() {
      return signedIn() && request.auth.token.email == 'karim@aq8algerie.com';
    }

    function managerExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/managers/$(request.auth.token.email));
    }

    function managerData() {
      return get(/databases/$(database)/documents/managers/$(request.auth.token.email)).data;
    }

    function isActiveManagerFor(centerId) {
      return managerExists()
        && managerData().active == true
        && managerData().centerId == centerId;
    }

    function clientExists(clientId) {
      return exists(/databases/$(database)/documents/clients/$(clientId));
    }

    function clientData(clientId) {
      return get(/databases/$(database)/documents/clients/$(clientId)).data;
    }

    function isActiveManagerForClient(clientId) {
      return clientExists(clientId) && isActiveManagerFor(clientData(clientId).centerId);
    }

    match /centers/{centerId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /managers/{managerEmail} {
      allow read: if isSuperAdmin() || (signedIn() && request.auth.token.email == managerEmail);
      allow create, update, delete: if isSuperAdmin();
    }

    match /clients/{clientId} {
      allow read: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
      allow create: if isSuperAdmin() || isActiveManagerFor(request.resource.data.centerId);
      allow update: if isSuperAdmin()
        || (isActiveManagerFor(resource.data.centerId)
          && request.resource.data.centerId == resource.data.centerId);
      allow delete: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
    }

    match /appointments/{appointmentId} {
      allow read: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
      allow create: if isSuperAdmin() || isActiveManagerFor(request.resource.data.centerId);
      allow update: if isSuperAdmin()
        || (isActiveManagerFor(resource.data.centerId)
          && request.resource.data.centerId == resource.data.centerId);
      allow delete: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
    }

    match /client_packages/{clientPackageId} {
      allow read: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
      allow create: if isSuperAdmin() || isActiveManagerFor(request.resource.data.centerId);
      allow update: if isSuperAdmin()
        || (isActiveManagerFor(resource.data.centerId)
          && request.resource.data.centerId == resource.data.centerId);
      allow delete: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
    }

    match /payments/{paymentId} {
      allow read: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
      allow create: if isSuperAdmin() || isActiveManagerFor(request.resource.data.centerId);
      allow update: if isSuperAdmin()
        || (isActiveManagerFor(resource.data.centerId)
          && request.resource.data.centerId == resource.data.centerId);
      allow delete: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
    }

    match /measurements/{measurementId} {
      allow read: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
      allow create: if isSuperAdmin()
        || (isActiveManagerFor(request.resource.data.centerId)
          && isActiveManagerForClient(request.resource.data.clientId));
      allow update: if isSuperAdmin()
        || (isActiveManagerFor(resource.data.centerId)
          && request.resource.data.centerId == resource.data.centerId
          && request.resource.data.clientId == resource.data.clientId);
      allow delete: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
    }

    match /booking_requests/{requestId} {
      allow create: if request.resource.data.centerId is string
        && exists(/databases/$(database)/documents/centers/$(request.resource.data.centerId));
      allow read, update, delete: if isSuperAdmin() || isActiveManagerFor(resource.data.centerId);
    }

    match /contact_requests/{requestId} {
      allow create: if request.resource.data.status == 'new';
      allow read, update, delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}