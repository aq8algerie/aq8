rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveCrmUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userProfile().active == true;
    }

    function isSuperAdmin() {
      return isActiveCrmUser() && userProfile().role == 'super_admin';
    }

    function isCenterManager(centerId) {
      return isActiveCrmUser()
        && userProfile().role == 'center_manager'
        && userProfile().centerId == centerId;
    }

    function canAccessCenter(centerId) {
      return isSuperAdmin() || isCenterManager(centerId);
    }

    function isBookingCapacityMap(value) {
      return value is map
        && value.keys().hasOnly(['aq8', 'wonder'])
        && (!('aq8' in value) || (value.aq8 is number && value.aq8 >= 0 && value.aq8 <= 20))
        && (!('wonder' in value) || (value.wonder is number && value.wonder >= 0 && value.wonder <= 20));
    }

    function isTimeRange(value) {
      return value is map
        && value.keys().hasOnly(['start', 'end'])
        && value.start is string
        && value.end is string
        && value.start.matches('^([01][0-9]|2[0-3]):00$')
        && value.end.matches('^([01][0-9]|2[0-4]):00$');
    }

    function isBookingDayRanges(value) {
      return value is list
        && value.size() <= 4
        && (value.size() == 0 || isTimeRange(value[0]))
        && (value.size() <= 1 || isTimeRange(value[1]))
        && (value.size() <= 2 || isTimeRange(value[2]))
        && (value.size() <= 3 || isTimeRange(value[3]));
    }

    function isBookingHoursMap(value) {
      return value is map
        && value.keys().hasOnly(['0', '1', '2', '3', '4', '5', '6'])
        && (!('0' in value) || isBookingDayRanges(value['0']))
        && (!('1' in value) || isBookingDayRanges(value['1']))
        && (!('2' in value) || isBookingDayRanges(value['2']))
        && (!('3' in value) || isBookingDayRanges(value['3']))
        && (!('4' in value) || isBookingDayRanges(value['4']))
        && (!('5' in value) || isBookingDayRanges(value['5']))
        && (!('6' in value) || isBookingDayRanges(value['6']));
    }

    function isCenterBookingSettingsUpdate(centerId) {
      return isCenterManager(centerId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookingCapacity', 'bookingHours', 'updatedAt'])
        && (!('bookingCapacity' in request.resource.data) || isBookingCapacityMap(request.resource.data.bookingCapacity))
        && (!('bookingHours' in request.resource.data) || isBookingHoursMap(request.resource.data.bookingHours))
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is string);
    }

    function isPublicContactMessageCreate() {
      return request.resource.data.keys().hasOnly([
          'name', 'phone', 'email', 'requestType', 'centerId', 'message', 'status', 'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.phone.size() <= 40
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160
        && request.resource.data.requestType in ['general', 'reservation', 'partnership', 'recruitment']
        && request.resource.data.centerId is string
        && request.resource.data.centerId.size() > 0
        && request.resource.data.centerId.size() <= 80
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() <= 40;
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    match /centers/{centerId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isCenterBookingSettingsUpdate(centerId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /managers/{managerId} {
      allow read: if isSuperAdmin() || isCenterManager(resource.data.centerId);
      allow create, update, delete: if isSuperAdmin();
    }

    match /clients/{clientId} {
      allow get: if (isActiveCrmUser() && !exists(/databases/$(database)/documents/clients/$(clientId)))
        || canAccessCenter(resource.data.centerId);
      allow list: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /appointments/{appointmentId} {
      allow get: if (isActiveCrmUser() && !exists(/databases/$(database)/documents/appointments/$(appointmentId)))
        || canAccessCenter(resource.data.centerId);
      allow list: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /client_packages/{clientPackageId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /payments/{paymentId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /measurements/{measurementId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /appointment_slots/{centerId}/slots/{slotId} {
      allow read: if canAccessCenter(centerId);
      allow create: if canAccessCenter(centerId) && request.resource.data.centerId == centerId;
      allow update: if canAccessCenter(centerId)
        && resource.data.centerId == centerId
        && request.resource.data.centerId == centerId;
      allow delete: if canAccessCenter(centerId) && resource.data.centerId == centerId;
    }

    match /public_booking_slots/{centerId}/slots/{slotId} {
      allow read: if true;
      allow create: if canAccessCenter(centerId) && request.resource.data.centerId == centerId;
      allow update: if canAccessCenter(centerId)
        && resource.data.centerId == centerId
        && request.resource.data.centerId == centerId;
      allow delete: if canAccessCenter(centerId) && resource.data.centerId == centerId;
    }

    match /booking_requests/{requestId} {
      allow create: if false;
      allow read: if canAccessCenter(resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if isSuperAdmin();
    }

    match /contact_messages/{messageId} {
      allow create: if isPublicContactMessageCreate();
      allow read, update, delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
