rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveCrmUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userProfile().active == true;
    }

    function isSuperAdmin() {
      return isActiveCrmUser() && userProfile().role == 'super_admin';
    }

    function isCenterManager(centerId) {
      return isActiveCrmUser()
        && userProfile().role == 'center_manager'
        && userProfile().centerId == centerId;
    }

    function canAccessCenter(centerId) {
      return isSuperAdmin() || isCenterManager(centerId);
    }

    function isPublicBookingCreate() {
      return request.resource.data.keys().hasOnly([
          'centerId', 'centerName', 'firstName', 'lastName', 'phone', 'email',
          'service', 'bookingDate', 'bookingTime', 'status', 'createdAt'
        ])
        && request.resource.data.centerId is string
        && request.resource.data.centerName is string
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.phone is string
        && request.resource.data.status == 'pending';
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create, update, delete: if isSuperAdmin();
    }

    match /centers/{centerId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    match /managers/{managerId} {
      allow read: if isSuperAdmin() || isCenterManager(resource.data.centerId);
      allow create, update, delete: if isSuperAdmin();
    }

    match /clients/{clientId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /appointments/{appointmentId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /client_packages/{clientPackageId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /payments/{paymentId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /measurements/{measurementId} {
      allow read: if canAccessCenter(resource.data.centerId);
      allow create: if canAccessCenter(request.resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if canAccessCenter(resource.data.centerId);
    }

    match /booking_requests/{requestId} {
      allow create: if isPublicBookingCreate();
      allow read: if canAccessCenter(resource.data.centerId);
      allow update: if canAccessCenter(resource.data.centerId) && canAccessCenter(request.resource.data.centerId);
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}