# Firebase Web SDK configuration used by Vite.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="YOUR_MEASUREMENT_ID"

# Keep demo shortcuts disabled outside local development.
VITE_ENABLE_DEMO_LOGIN="false"

# GEMINI_API_KEY: Required for Gemini AI API calls, if AI features are enabled.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where this app is hosted.
APP_URL="MY_APP_URL"

# Email notifications through Resend.
# EMAIL_NOTIFICATIONS_ENABLED=false disables all transactional emails.
EMAIL_NOTIFICATIONS_ENABLED="true"
EMAIL_ADMIN_COPIES_ENABLED="false"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
EMAIL_FROM="AQ8 Algerie <notifications@aq8algerie-dz.com>"
EMAIL_REPLY_TO="notifications@aq8algerie-dz.com"
ADMIN_NOTIFICATION_EMAILS="notifications@aq8algerie-dz.com"